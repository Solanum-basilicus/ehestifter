# Service Bus
SERVICEBUS_CONNECTION_STRING="Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=..."
SERVICEBUS_QUEUE_NAME="enrichment-requests"

# Gateway - primary, normally Azure Function App
GATEWAY_BASE_URL="https://YOUR-GATEWAY.azurewebsites.net"
GATEWAY_API_KEY="YOUR_WORKER_API_KEY"

# Gateway - optional alternative, e.g. GCP Cloud Run Gateway.
# Keep USE_GATEWAY_ALTERNATIVE=0 for normal operation.
# Set USE_GATEWAY_ALTERNATIVE=1 to make the worker call this pair instead.
# Switching is explicit, only one is used across all worker operations. No failowers.
USE_GATEWAY_ALTERNATIVE="0"
GATEWAY_ALTERNATIVE_BASE_URL="https://YOUR-GATEWAY-GCP.run.app"
GATEWAY_ALTERNATIVE_API_KEY="YOUR_GCP_GATEWAY_API_KEY"

# Worker behavior
ENRICHER_TYPE="compatibility.v1"
WORKER_POLL_WAIT_SECONDS="10"
WORKER_BACKOFF_SECONDS="5"
LEASE_TTL_SECONDS="3600"

# Of you want to eat all your storage with logs, set it to DEBUG
LOG_LEVEL=INFO

# You need only one inference provider. Currently Llama.cpp is used. There's no easy switch, need to update code. 
# Ollama on host (default API base is http://localhost:11434/api) :contentReference[oaicite:3]{index=3}
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# llama.cpp native server (OpenAI-compatible endpoint lives under /v1)
LLAMA_CPP_BASE_URL="http://127.0.0.1:8081"
