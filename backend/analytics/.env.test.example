# Default local mode expects the service already running at localhost:8080.
ANALYTICS_TEST_TARGET=local
ANALYTICS_LOCAL_BASE_URL=http://localhost:8080

# Prod mode:
# ANALYTICS_TEST_TARGET=prod
# ANALYTICS_PROD_BASE_URL=https://ehestifter-analytics-<hash>-ew.a.run.app

# Local temporary keys may match .env.local.
# For prod mode, inject real values from Secret Manager manually or via your deploy workflow.
ANALYTICS_FUNCTION_KEY_JOBS=jobs-key
ANALYTICS_FUNCTION_KEY_USERS=users-key
ANALYTICS_FUNCTION_KEY_SCHEDULER=scheduler-key
ANALYTICS_FUNCTION_KEY_OPERATOR=operator-key

# Optional exact DB verification.
# Keep disabled unless you deliberately want test process DB access.
ANALYTICS_TEST_ENABLE_DB_ASSERTS=0
ANALYTICS_TEST_SQL_CONNECTION_STRING=